{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@calsnap/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "prisma/**/*"]
}
