{
  "name": "calsnap",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@8.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @calsnap/backend run dev",
    "dev:frontend": "pnpm --filter @calsnap/frontend run dev",
    "build": "pnpm --filter @calsnap/shared run build && pnpm -r --parallel run build",
    "db:push": "pnpm --filter @calsnap/backend run db:push",
    "db:migrate": "pnpm --filter @calsnap/backend run db:migrate",
    "db:studio": "pnpm --filter @calsnap/backend run db:studio",
    "db:seed": "pnpm --filter @calsnap/backend run db:seed",
    "lint": "pnpm -r run lint"
  }
}
