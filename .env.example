# Database
POSTGRES_USER=calsnap
POSTGRES_PASSWORD=calsnap_pass
POSTGRES_DB=calsnap
DATABASE_URL=postgresql://calsnap:calsnap_pass@localhost:5432/calsnap

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_64chars
JWT_REFRESH_SECRET=change_me_refresh_secret_64chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
FRONTEND_URL=http://localhost:3000
PORT=4000
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
